{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dip.local/schemas/public-projections/public-requirement-register-projection.schema.json",
  "title": "DIP Public Requirement Register Projection",
  "allOf": [
    {"$ref": "public-projection-common.schema.json#/$defs/projectionEnvelope"},
    {
      "type": "object",
      "required": ["records"],
      "properties": {
        "projection_id": {"const": "DIP-PUBLIC-REQUIREMENT-REGISTER"},
        "source_register_id": {"const": "DIP-PUB-REQUIREMENT-REGISTER"},
        "records": {
          "type": "array",
          "items": {
            "allOf": [
              {"$ref": "public-projection-common.schema.json#/$defs/normativeRecord"},
              {"properties": {"id": {"pattern": "^DIP-REQ-[0-9]{4}$"}, "record_kind": {"const": "requirement"}}}
            ]
          }
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
