{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dip.local/schemas/public-projections/public-contradiction-log-projection.schema.json",
  "title": "DIP Public Potential-Contradiction Log Projection",
  "allOf": [
    {"$ref": "public-projection-common.schema.json#/$defs/projectionEnvelope"},
    {
      "type": "object",
      "required": ["blocking_contradiction_found", "records"],
      "properties": {
        "projection_id": {"const": "DIP-PUBLIC-CONTRADICTION-LOG"},
        "source_register_id": {"const": "DIP-PUB-CONTRADICTION-LOG"},
        "blocking_contradiction_found": {"type": "boolean"},
        "records": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "title", "description", "potential_impact", "lifecycle_status", "resolution", "blocking", "architectural_decision_reopened"],
            "properties": {
              "id": {"type": "string", "pattern": "^PUB-CON-[0-9]{4}$"},
              "title": {"type": "string", "minLength": 1},
              "description": {"type": "string", "minLength": 1},
              "potential_impact": {"type": "string", "minLength": 1},
              "lifecycle_status": {"type": "string", "minLength": 1},
              "resolution": {"type": "string", "minLength": 1},
              "blocking": {"type": "boolean"},
              "architectural_decision_reopened": {"type": "boolean"}
            }
          }
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
