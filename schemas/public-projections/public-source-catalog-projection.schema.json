{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dip.local/schemas/public-projections/public-source-catalog-projection.schema.json",
  "title": "DIP Public Source Catalog Projection",
  "allOf": [
    {"$ref": "public-projection-common.schema.json#/$defs/projectionEnvelope"},
    {
      "type": "object",
      "required": ["records"],
      "properties": {
        "projection_id": {"const": "DIP-PUBLIC-SOURCE-CATALOG"},
        "source_register_id": {"const": "DIP-PUB-SOURCE-CATALOG"},
        "records": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "title",
              "normalized_publication_statement",
              "lifecycle_status",
              "public_build_eligible",
              "blueprint_destinations",
              "relationships"
            ],
            "properties": {
              "id": {"type": "string", "pattern": "^DIP-SRC-[0-9]{4}$"},
              "title": {"type": "string", "minLength": 1},
              "normalized_publication_statement": {"type": "string", "minLength": 1},
              "lifecycle_status": {"type": "string", "minLength": 1},
              "public_build_eligible": {"const": true},
              "blueprint_destinations": {"$ref": "public-projection-common.schema.json#/$defs/stringArray"},
              "relationships": {"$ref": "public-projection-common.schema.json#/$defs/relationships"}
            }
          }
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
