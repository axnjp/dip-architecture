{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dip.local/schemas/public-projections/public-gap-log-projection.schema.json",
  "title": "DIP Public Publication-Gap Log Projection",
  "allOf": [
    {"$ref": "public-projection-common.schema.json#/$defs/projectionEnvelope"},
    {
      "type": "object",
      "required": ["records"],
      "properties": {
        "projection_id": {"const": "DIP-PUBLIC-GAP-LOG"},
        "source_register_id": {"const": "DIP-PUB-GAP-LOG"},
        "records": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "title", "description", "impact", "lifecycle_status", "blocking_gate_ids"],
            "properties": {
              "id": {"type": "string", "pattern": "^PUB-GAP-[0-9]{4}$"},
              "title": {"type": "string", "minLength": 1},
              "description": {"type": "string", "minLength": 1},
              "impact": {"type": "string", "minLength": 1},
              "lifecycle_status": {"type": "string", "minLength": 1},
              "blocking_gate_ids": {"$ref": "public-projection-common.schema.json#/$defs/identifierArray"}
            }
          }
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
