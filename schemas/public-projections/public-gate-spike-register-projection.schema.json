{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dip.local/schemas/public-projections/public-gate-spike-register-projection.schema.json",
  "title": "DIP Public Gate and Research-Spike Register Projection",
  "allOf": [
    {"$ref": "public-projection-common.schema.json#/$defs/projectionEnvelope"},
    {
      "type": "object",
      "required": ["gates", "research_spikes"],
      "properties": {
        "projection_id": {"const": "DIP-PUBLIC-GATE-SPIKE-REGISTER"},
        "source_register_id": {"const": "DIP-PUB-GATE-SPIKE-REGISTER"},
        "gates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "title", "lifecycle_status", "normalized_publication_statement", "owning_phase", "public_pass_criteria", "relationships"],
            "properties": {
              "id": {"type": "string", "pattern": "^DIP-GATE-[0-9]{4}$"},
              "alias": {"type": ["string", "null"]},
              "title": {"type": "string", "minLength": 1},
              "lifecycle_status": {"type": "string", "minLength": 1},
              "normalized_publication_statement": {"type": "string", "minLength": 1},
              "owning_phase": {"type": "string", "minLength": 1},
              "public_pass_criteria": {"$ref": "public-projection-common.schema.json#/$defs/stringArray"},
              "relationships": {"$ref": "public-projection-common.schema.json#/$defs/relationships"}
            }
          }
        },
        "research_spikes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "title", "lifecycle_status", "normalized_publication_statement", "public_exit_criteria", "relationships"],
            "properties": {
              "id": {"type": "string", "pattern": "^DIP-SPIKE-[0-9]{4}$"},
              "alias": {"type": ["string", "null"]},
              "title": {"type": "string", "minLength": 1},
              "lifecycle_status": {"type": "string", "minLength": 1},
              "normalized_publication_statement": {"type": "string", "minLength": 1},
              "public_exit_criteria": {"$ref": "public-projection-common.schema.json#/$defs/stringArray"},
              "relationships": {"$ref": "public-projection-common.schema.json#/$defs/relationships"}
            }
          }
        }
      }
    }
  ],
  "unevaluatedProperties": false
}
